# LatentSpec configuration

# Database
DATABASE_URL=postgresql+asyncpg://latentspec:latentspec@localhost:5432/latentspec
DATABASE_SYNC_URL=postgresql://latentspec:latentspec@localhost:5432/latentspec

# Redis (cache + Celery broker)
REDIS_URL=redis://localhost:6379/0

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Mining configuration (§3.2 / §3.4 defaults)
MINING_BATCH_SIZE=75
MINING_MIN_SUPPORT=0.6
CONFIDENCE_REJECT_THRESHOLD=0.6
CONFIDENCE_REVIEW_THRESHOLD=0.8

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Storage tiers (§8.2)
HOT_RETENTION_DAYS=30
WARM_RETENTION_DAYS=90
